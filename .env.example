# ─── UPLIZD / Langflow ───────────────────────────────────────────
UPLIZD_API_KEY=your_api_key_here
# After installing "Meeting Scheduler Agent" from Marketplace, paste Flow ID from the flow URL
UPLIZD_FLOW_ID=your_flow_id_here
UPLIZD_BASE_URL=https://studio.uplizd.ai

# ─── Proxy server ────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ─── Optional: override flow input/output types ──────────────────
FLOW_INPUT_TYPE=chat
FLOW_OUTPUT_TYPE=chat
